{
  "name": "plant-care-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch --inspect server/src/index.ts",
    "typecheck": "vue-tsc --noEmit && tsc -p server/tsconfig.json --noEmit",
    "typecheck:client": "vue-tsc --noEmit",
    "typecheck:server": "tsc -p server/tsconfig.json --noEmit",
    "build": "npm run typecheck && vite build && tsc -p server/tsconfig.json",
    "build:client": "npm run typecheck:client && vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "preview": "vite preview",
    "start": "node server/dist/index.js"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dayjs": "^1.11.0",
    "echarts": "^5.4.0",
    "express": "^4.18.0",
    "file-type": "^16.5.4",
    "heic-convert": "^2.1.0",
    "heic2any": "^0.0.4",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pinia": "^2.1.0",
    "sharp": "^0.34.5",
    "sqlite3": "^5.1.7",
    "vant": "^4.8.0",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/heic-convert": "^2.1.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/morgan": "^1.9.0",
    "@types/multer": "^1.4.0",
    "@types/node": "^20.10.0",
    "@types/sqlite3": "^3.1.11",
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^8.2.0",
    "sass": "^1.69.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vue-tsc": "^3.2.8"
  }
}
